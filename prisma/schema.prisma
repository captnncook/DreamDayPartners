generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  role       String   // admin | planner | team_member | couple | vendor
  vendorType String?  // bloemist | dj | catering | fotograaf | etc.
  avatar     String?
  isPremium            Boolean  @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ownedWeddings        Wedding[]                      @relation("WeddingOwner")
  teamMemberships      WeddingTeamMember[]
  sentMessages         Message[]
  assignedTasks        Task[]
  uploadedDocuments    Document[]
  notifications        Notification[]
  dmParticipations     DirectConversationParticipant[]
  sentDirectMessages   DirectMessage[]
  vendorReviews        VendorReview[]

  @@map("users")
}

model DirectConversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants DirectConversationParticipant[]
  messages     DirectMessage[]

  @@map("direct_conversations")
}

model DirectConversationParticipant {
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("direct_conversation_participants")
}

model DirectMessage {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation(fields: [senderId], references: [id])

  @@map("direct_messages")
}

model Wedding {
  id           String   @id @default(uuid())
  weddingCode  String   @unique
  title        String
  date         DateTime
  venue        String?
  status       String   @default("planning")
  coupleEmail1 String
  coupleEmail2 String
  ownerId      String
  isPremium    Boolean  @default(false)
  notes        String?
  rsvpToken    String   @unique @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner           User                  @relation("WeddingOwner", fields: [ownerId], references: [id])
  teamMembers     WeddingTeamMember[]
  vendors         WeddingVendor[]
  guests          Guest[]
  budget          Budget?
  tasks           Task[]
  draaiboeken     Draaiboek[]
  threads         MessageThread[]
  documents       Document[]
  notifications   Notification[]
  seatTables      SeatingTable[]
  vendorInvites   VendorWeddingInvite[]
  vendorReviews   VendorReview[]

  @@map("weddings")
}

model WeddingTeamMember {
  id        String   @id @default(uuid())
  weddingId String
  userId    String
  role      String   // planner | team_member | couple | vendor_contact
  createdAt DateTime @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([weddingId, userId])
  @@map("wedding_team_members")
}

model Vendor {
  id            String   @id @default(uuid())
  name          String
  category      String
  contactPerson String?
  email         String?
  phone         String?
  website       String?
  notes         String?
  userId        String?
  description   String?
  isPremium     Boolean  @default(false)
  coverPhoto    String?
  emblemPhoto   String?
  photos        String[]
  city          String?
  latitude      Float?
  longitude     Float?
  priceFrom       Int?
  priceTo         Int?
  priceUnit       String?
  specializations String[]
  busyDates       String[]
  createdAt       DateTime @default(now())

  weddingVendors   WeddingVendor[]
  draaiboekItems   DraaiboekItem[]
  budgetItems      BudgetItem[]
  weddingInvites   VendorWeddingInvite[]
  contactRequests  VendorContactRequest[]
  reviews          VendorReview[]

  @@map("vendors")
}

model VendorContactRequest {
  id          String    @id @default(uuid())
  vendorId    String
  name        String
  email       String
  phone       String?
  message     String
  weddingDate DateTime?
  createdAt   DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_contact_requests")
}

model VendorReview {
  id        String   @id @default(uuid())
  vendorId  String
  weddingId String
  authorId  String
  rating    Int
  text      String?
  createdAt DateTime @default(now())

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, weddingId, authorId])
  @@map("vendor_reviews")
}

model VendorWeddingInvite {
  id           String    @id @default(uuid())
  vendorId     String
  email1       String
  email2       String?
  weddingDate  DateTime
  weddingTitle String?
  weddingId    String?
  notes        String?
  createdAt    DateTime  @default(now())

  vendor  Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wedding Wedding? @relation(fields: [weddingId], references: [id], onDelete: SetNull)

  @@map("vendor_wedding_invites")
}

model WeddingVendor {
  id              String    @id @default(uuid())
  weddingId       String
  vendorId        String
  status          String    @default("lead")      // lead | booked | in_progress | ready | completed
  portalAccess    Boolean   @default(false)
  notes           String?
  contractUrl     String?
  intakeData      Json?
  depositAmount   Float?
  depositDue      DateTime?
  depositPaid     Boolean   @default(false)
  finalAmount     Float?
  finalDue        DateTime?
  finalPaid       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wedding        Wedding         @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  deliverables   Deliverable[]
  draaiboekItems DraaiboekItem[]
  tasks          Task[]
  documents      Document[]

  @@unique([weddingId, vendorId])
  @@map("wedding_vendors")
}

model Guest {
  id         String   @id @default(uuid())
  weddingId  String
  name       String
  email      String?
  phone      String?
  side       String   @default("both")
  rsvpStatus String   @default("invited")
  dietary    String?
  plusOne    Boolean  @default(false)
  tableId    String?
  rsvpToken  String   @unique @default(uuid())
  createdAt  DateTime @default(now())

  wedding      Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  seatingTable SeatingTable? @relation(fields: [tableId], references: [id])

  @@map("guests")
}

model SeatingTable {
  id        String  @id @default(uuid())
  weddingId String
  label     String
  capacity  Int     @default(8)
  notes     String?

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests  Guest[]

  @@map("seating_tables")
}

model Budget {
  id          String @id @default(uuid())
  weddingId   String @unique
  totalAmount Float  @default(0)
  currency    String @default("EUR")

  wedding Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  items   BudgetItem[]

  @@map("budgets")
}

model BudgetItem {
  id          String  @id @default(uuid())
  budgetId    String
  category    String
  description String
  estimated   Float   @default(0)
  actual      Float   @default(0)
  vendorId    String?
  payStatus   String  @default("pending")
  invoiceUrl  String?

  budget Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@map("budget_items")
}

model Task {
  id          String    @id @default(uuid())
  weddingId   String
  title       String
  description String?
  dueDate     DateTime?
  category    String    @default("general")
  assignedTo  String?
  status      String    @default("open")
  priority    String    @default("medium")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vendorBookingId String?

  wedding       Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  assignedUser  User?          @relation(fields: [assignedTo], references: [id])
  vendorBooking WeddingVendor? @relation(fields: [vendorBookingId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

model Draaiboek {
  id        String   @id @default(uuid())
  weddingId String
  title     String
  version   String   @default("1.0")
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding Wedding         @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  items   DraaiboekItem[]

  @@map("draaiboeken")
}

model DraaiboekItem {
  id              String  @id @default(uuid())
  draaiboekId     String
  startTime       String
  duration        Int     @default(30)
  title           String
  description     String?
  location        String?
  sortOrder       Int     @default(0)
  assignedUserId  String?
  vendorId        String?
  vendorBookingId String?
  phase           String?  // arrival | setup | perform | teardown | custom
  notes           String?
  isPublic        Boolean  @default(false)

  draaiboek     Draaiboek      @relation(fields: [draaiboekId], references: [id], onDelete: Cascade)
  vendor        Vendor?        @relation(fields: [vendorId], references: [id])
  vendorBooking WeddingVendor? @relation(fields: [vendorBookingId], references: [id], onDelete: SetNull)

  @@map("draaiboek_items")
}

model MessageThread {
  id        String   @id @default(uuid())
  weddingId String
  type      String   // internal | couple | vendor
  vendorId  String?
  subject   String?
  createdAt DateTime @default(now())

  wedding  Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("message_threads")
}

model Message {
  id            String   @id @default(uuid())
  threadId      String
  senderId      String
  content       String
  hasAttachment Boolean  @default(false)
  createdAt     DateTime @default(now())

  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User          @relation(fields: [senderId], references: [id])
  reads       MessageRead[]
  attachments Attachment[]

  @@map("messages")
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_reads")
}

model Attachment {
  id        String @id @default(uuid())
  messageId String
  fileUrl   String
  fileName  String
  fileType  String
  size      Int

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Document {
  id         String   @id @default(uuid())
  weddingId  String
  name       String
  fileKey    String
  mimeType   String   @default("application/octet-stream")
  fileSize   Int      @default(0)
  category   String   @default("overig") // inspiratie | offerte | factuur | contract | overig
  visibility String   @default("team")   // team | couple | vendor | private
  uploadedBy String
  createdAt  DateTime @default(now())

  vendorBookingId String?

  wedding       Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  uploader      User           @relation(fields: [uploadedBy], references: [id])
  vendorBooking WeddingVendor? @relation(fields: [vendorBookingId], references: [id], onDelete: SetNull)

  @@map("documents")
}

model Deliverable {
  id               String    @id @default(uuid())
  vendorBookingId  String
  key              String
  label            String
  status           String    @default("pending") // pending | submitted | approved | rejected
  dueDate          DateTime?
  approvalRequired Boolean   @default(false)
  notes            String?
  fileUrl          String?
  createdAt        DateTime  @default(now())

  vendorBooking WeddingVendor @relation(fields: [vendorBookingId], references: [id], onDelete: Cascade)

  @@map("deliverables")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  weddingId   String?
  type        String
  content     String
  relatedType String?
  relatedId   String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wedding Wedding? @relation(fields: [weddingId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

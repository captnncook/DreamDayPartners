# PostgreSQL — Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Cloudflare R2 — get these from the R2 dashboard (Settings > API tokens)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="dreamday-files"

# Public base URL for your app (used for CORS on R2 in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend — get from resend.com dashboard (API Keys)
RESEND_API_KEY="re_xxxxxxxx"
MAIL_FROM="DreamDay Platform <noreply@yourdomain.nl>"
ADMIN_NOTIFY_EMAIL="info@dreamdaypartners.nl"

# Google / Apple OAuth (optional — only needed for "Sign in with Google/Apple")
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_KEY_ID=""
APPLE_TEAM_ID=""
APPLE_PRIVATE_KEY=""

# PostgreSQL — Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Cloudflare R2 — get these from the R2 dashboard (Settings > API tokens)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="dreamday-files"

# Public base URL for your app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
